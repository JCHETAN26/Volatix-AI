# ChainGuard-Core dashboard env (Phase 5).
#
# For local dev: `make port-forward-pg` in another terminal, then point
# DATABASE_URL at the forwarded socket using the password the Bitnami chart
# stored in the chain-db-postgresql Secret:
#
#   DATABASE_URL=postgres://postgres:PASSWORD@localhost:5432/postgres
#
# For Vercel: set DATABASE_URL in the project settings. The app gracefully
# renders an empty state when the DB is unreachable.

DATABASE_URL=
# Optional override; defaults to 200ms.
DB_CONNECT_TIMEOUT_MS=2000
# How often the SSE stream polls Postgres for new rows. Lower = lower
# end-to-end latency, higher = lower DB load.
SSE_POLL_MS=500
